{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "LambdaCreateUpdate",
      "Effect": "Allow",
      "Action": [
        "lambda:CreateFunction",
        "lambda:UpdateFunctionCode",
        "lambda:UpdateFunctionConfiguration",
        "lambda:GetFunction",
        "lambda:GetFunctionUrlConfig",
        "lambda:CreateFunctionUrlConfig",
        "lambda:AddPermission"
      ],
      "Resource": [
        "arn:aws:lambda:us-east-1:494777943750:function:logicall-*"
      ]
    },
    {
      "Sid": "LambdaPassRole",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": "arn:aws:iam::494777943750:role/logicall-*-role",
      "Condition": {
        "StringEquals": {
          "iam:PassedToService": "lambda.amazonaws.com"
        }
      }
    }
  ]
}
